{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A video production project for a specific country.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "description": "Name of the country or episode." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "scriptRaw": { "type": "string", "description": "The raw tabular script text." },
        "globalStylePrompt": { "type": "string", "description": "Base prompt for visual consistency." },
        "styleReferenceId": { "type": "string", "description": "ID of the selected style from library." }
      },
      "required": ["name", "createdAt"]
    },
    "Frame": {
      "title": "Frame",
      "description": "An individual visual frame from the script.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "frameNumber": { "type": "string" },
        "originalDescription": { "type": "string" },
        "narratedText": { "type": "string" },
        "visualIntent": { "type": "string", "description": "Cleaned visual core for image generation." },
        "category": { "type": "string", "enum": ["landscape", "monument", "city", "animal", "food", "culture", "map", "object"] },
        "status": { "type": "string", "enum": ["pending", "selected", "generated", "skipped"] },
        "generatedImageUrl": { "type": "string" },
        "generationPrompt": { "type": "string" },
        "preferred": { "type": "boolean" }
      },
      "required": ["projectId", "frameNumber", "status"]
    },
    "StyleReference": {
      "title": "Style Reference",
      "description": "Reference images to maintain aesthetic consistency.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string", "description": "Optional project-specific reference." },
        "name": { "type": "string" },
        "stylePrompt": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name"]
    },
    "StyleImage": {
      "title": "Style Image",
      "description": "A single image document within a style reference.",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["url"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of video projects."
    },
    "/projects/{projectId}/frames/{frameId}": {
      "schema": "Frame",
      "description": "Frames associated with a project."
    },
    "/styleReferences/{refId}": {
      "schema": "StyleReference",
      "description": "Global or project-specific style references."
    },
    "/styleReferences/{refId}/images/{imageId}": {
      "schema": "StyleImage",
      "description": "Individual images for a style reference."
    }
  }
}
