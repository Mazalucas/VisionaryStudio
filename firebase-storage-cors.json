[
  {
    "origin": ["*"],
    "method": ["GET", "HEAD", "POST", "PUT", "DELETE", "OPTIONS"],
    "responseHeader": [
      "Content-Type",
      "Authorization",
      "Content-Length",
      "Content-Disposition",
      "x-goog-resumable",
      "x-goog-upload-command",
      "x-goog-upload-header-content-length",
      "x-goog-upload-header-content-type",
      "x-goog-upload-protocol",
      "x-goog-upload-status",
      "x-goog-upload-url",
      "X-Firebase-Storage-Version"
    ],
    "maxAgeSeconds": 3600
  }
]
